# genbu.yaml.sample - Genbu configuration example
# See: https://github.com/dreadnought-inc/genbu

version: "1"

# Default dump output format: dotenv, ini, toml, json
# Can be overridden by --format CLI flag.
dump_format: dotenv

# Global defaults applied to all variables.
# Variables can override these individually.
defaults:
  required: true

variables:
  # ===========================================================================
  # Literal values
  # ===========================================================================
  # Set a fixed value directly.
  - name: APP_ENV
    value: "production"
    validate:
      enum: ["development", "staging", "production"]

  - name: APP_PORT
    value: "8080"
    validate:
      pattern: "^[0-9]+$"

  # ===========================================================================
  # Default values
  # ===========================================================================
  # "default" is used as a fallback when the resolved value is empty.
  - name: LOG_LEVEL
    source:
      type: env
    default: "info"
    validate:
      enum: ["debug", "info", "warn", "error"]

  # ===========================================================================
  # Variable references — ${VAR}
  # ===========================================================================
  # Reference other variables with ${VAR_NAME}.
  # Dependency order is resolved automatically via topological sort.
  # Circular references (A -> B -> A) are detected and cause an error.
  - name: DB_HOST
    value: "db.example.com"

  - name: DB_PORT
    default: "5432"

  - name: DB_USER
    value: "admin"

  - name: DB_PASSWORD
    value: "s3cret"

  - name: DATABASE_URL
    value: "postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/mydb"
    validate:
      pattern: "^postgres://"

  # ===========================================================================
  # Function expressions — ${{ expr }}
  # ===========================================================================
  # Evaluate built-in functions with ${{ function(args) }}.
  # Functions can be nested: ${{ outer(inner(arg)) }}
  # Variable names inside ${{ }} are resolved as references.

  # --- Encoding ---
  - name: ENCODED_VALUE
    value: "${{ base64encode(DB_PASSWORD) }}"
    # Other encoding functions: base64decode, tohex, fromhex

  # --- Hashing (MD5/SHA-1 intentionally excluded as insecure) ---
  - name: PASSWORD_HASH
    value: "${{ sha256(DB_PASSWORD) }}"
    # Also available: sha384, sha512

  # --- Password hashing ---
  - name: BCRYPT_HASH
    value: "${{ bcrypt(DB_PASSWORD, 12) }}"
    # Cost parameter is optional (default: 10)

  # --- Random values ---
  - name: SESSION_SECRET
    value: "${{ random_hex(32) }}"
    # random_hex(n): n bytes of randomness as hex (output = 2n chars)
    # random_string(n): n alphanumeric characters

  # --- Date/Time ---
  # All date/time functions use UTC and accept an optional format argument.
  # Format: Go layout string or alias (rfc3339, iso8601, unix, unixmilli,
  #         rfc822, rfc850, rfc1123, kitchen, ansic, stamp)
  - name: BUILD_DATE
    value: "${{ date() }}"
    # Default: "2006-01-02"

  - name: BUILD_TIMESTAMP
    value: "${{ timestamp() }}"
    # Default: Unix epoch seconds

  - name: DEPLOY_TIME
    value: "${{ datetime('rfc3339') }}"
    # Default: RFC3339 format

  - name: LOG_TIME
    value: "${{ time('15:04:05') }}"
    # Default: "15:04:05"

  # Custom format example:
  - name: DEPLOY_LABEL
    value: "deploy-${{ date('20060102') }}-${{ random_string(8) }}"

  # --- String functions ---
  - name: APP_ENV_UPPER
    value: "${{ upper(APP_ENV) }}"
    # Also available: lower, trim, replace(s, old, new),
    #                 substr(s, start[, len]), concat(a, b, ...)

  # --- Nested functions ---
  - name: SECRET_TOKEN
    value: "${{ tohex(bcrypt(random_string(16), 4)) }}"

  # ===========================================================================
  # AWS SSM Parameter Store
  # ===========================================================================
  # Requires AWS credentials (env vars, IAM role, instance profile, etc.)
  - name: SSM_DATABASE_URL
    source:
      type: aws-ssm
      path: "/myapp/prod/database-url"
      region: "ap-northeast-1"    # optional: override default region
    validate:
      required: true
      pattern: "^postgres://"
      min_length: 10

  # ===========================================================================
  # AWS Secrets Manager
  # ===========================================================================
  # Fetch a plain string secret.
  - name: JWT_SECRET
    source:
      type: aws-secretsmanager
      secret_id: "myapp/prod/jwt-secret"
    validate:
      required: true
      min_length: 64
      max_length: 256

  # Fetch a specific key from a JSON secret.
  # If the secret value is {"api_key":"abc123","api_secret":"xyz789"},
  # json_key extracts just that key's value.
  - name: EXTERNAL_API_KEY
    source:
      type: aws-secretsmanager
      secret_id: "myapp/prod/external-api"
      json_key: "api_key"
    validate:
      required: true
      min_length: 16

  # ===========================================================================
  # Existing environment variable (read + validate)
  # ===========================================================================
  # Read a value already set in the environment.
  # Useful for validating variables injected by the container runtime.
  - name: AWS_REGION
    source:
      type: env
    validate:
      required: true
      enum: ["ap-northeast-1", "us-east-1", "eu-west-1"]

  # ===========================================================================
  # Validate-only
  # ===========================================================================
  # No source or value: reads the variable from the current environment
  # and validates it. Does not overwrite the existing value.
  - name: HOME
    validate:
      required: true

# ===========================================================================
# Groups
# ===========================================================================
# Group variables that share common source configuration.
# Group-level source fields are inherited by each variable,
# but variable-level fields take precedence.
groups:
  - name: database-credentials
    source:
      type: aws-ssm
      region: "ap-northeast-1"
    variables:
      - name: SSM_DB_HOST
        source:
          path: "/myapp/prod/db-host"
        validate:
          required: true

      - name: SSM_DB_PORT
        source:
          path: "/myapp/prod/db-port"
        validate:
          pattern: "^[0-9]+$"

      - name: SSM_DB_USER
        source:
          path: "/myapp/prod/db-user"

      - name: SSM_DB_PASSWORD
        source:
          path: "/myapp/prod/db-password"
        validate:
          min_length: 16

  - name: redis
    source:
      type: aws-secretsmanager
      region: "ap-northeast-1"
    variables:
      - name: REDIS_URL
        source:
          secret_id: "myapp/prod/redis-url"
        validate:
          pattern: "^redis://"

# ===========================================================================
# Usage
# ===========================================================================
#
#   # Resolve, validate, and exec your application
#   genbu exec -c genbu.yaml -- /app/server
#
#   # Validate only (useful in CI)
#   genbu validate -c genbu.yaml
#
#   # Dump resolved values (default format: dotenv, or dump_format in YAML)
#   genbu dump -c genbu.yaml
#   genbu dump -c genbu.yaml --format toml
#   genbu dump -c genbu.yaml --format json --mask
#
#   # Import existing config to generate genbu.yaml template
#   genbu import .env > genbu.yaml
#   genbu import config.ini > genbu.yaml
#   genbu import --format toml settings.toml > genbu.yaml
#
#   # Use as Docker ENTRYPOINT
#   ENTRYPOINT ["genbu", "exec", "-c", "/etc/genbu.yaml", "--"]
#   CMD ["/app/server"]
#
# ===========================================================================
# Function reference
# ===========================================================================
#
# Encoding:    base64encode(s), base64decode(s), tohex(s), fromhex(s)
# Hashing:     sha256(s), sha384(s), sha512(s)      (MD5/SHA-1 excluded)
# Password:    bcrypt(s [, cost])
# Random:      random_string(len), random_hex(bytes)
# Date/Time:   date([fmt]), time([fmt]), datetime([fmt]), timestamp([fmt])
#              Aliases: rfc3339, iso8601, unix, unixmilli, rfc822, rfc850,
#                       rfc1123, kitchen, ansic, stamp
# String:      upper(s), lower(s), trim(s), replace(s, old, new),
#              substr(s, start [, len]), concat(a, b, ...)
